# Database
DATABASE_URL=postgresql://igbot:igbot_pass@postgres:5432/igbot

# Redis
REDIS_URL=redis://redis:6379/0

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Security — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=your-jwt-secret-key-min-32-chars
ENCRYPTION_KEY=your-fernet-key-base64-44-chars

# App
ENVIRONMENT=production
LOG_LEVEL=INFO
POSTGRES_USER=igbot
POSTGRES_PASSWORD=igbot_pass
POSTGRES_DB=igbot
