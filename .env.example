# Database
DATABASE_URL=postgresql://igbot:CHANGE_ME_db_password@postgres:5432/igbot

# Redis
REDIS_URL=redis://redis:6379/0

# Anthropic — get at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Security — generate with commands below, never reuse defaults
# ENCRYPTION_KEY: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECRET_KEY:     python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_min_32_chars_random_string
ENCRYPTION_KEY=CHANGE_ME_fernet_base64_44_char_key

# App
ENVIRONMENT=production
LOG_LEVEL=INFO

# PostgreSQL container — must match DATABASE_URL credentials above
POSTGRES_USER=igbot
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=igbot
